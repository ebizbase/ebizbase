# ==================================================
# GLOBAL LOGGING ENVIRONMENT VARIABLES FOR LOCAL
# ==================================================

# LOG_FORMAT: text, json
# Default: json
LOG_FORMAT=text

# LOG_LEVEL: trace, debug, info, warn, error, fatal or silent
# Default: info
# Using on service-logger library project
LOG_LEVEL=trace


# ==================================================
# INFRASTRUCTURE ENVIRONMENT VARIABLES FOR LOCAL
# ==================================================
MONGODB_URL=mongodb://mongodb.fbi.com
ELASTIC_URLS=http://elastic.fbi.com
RABITMQ_URL=amqp://rabbitmq.fbi.com
REDIS_URL=amqp://redis.fbi.com
STATIC_URL=http://static.fbi.com
MAIN_DOMAIN=lacolhost.com
TENANT_DOMAIN=localtest.me
