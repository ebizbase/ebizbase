{
  "name": "nest-grpc-testing",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "components/libraries/nest-grpc-testing/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/components/libraries/nest-grpc-testing",
        "main": "components/libraries/nest-grpc-testing/src/index.ts",
        "tsConfig": "components/libraries/nest-grpc-testing/tsconfig.lib.json",
        "assets": ["components/libraries/nest-grpc-testing/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "components/libraries/nest-grpc-testing/jest.config.ts"
      }
    }
  }
}
