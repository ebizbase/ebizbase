{
  "name": "nest-translator",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "components/libraries/nest-translator/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/components/libraries/nest-translator",
        "main": "components/libraries/nest-translator/src/index.ts",
        "tsConfig": "components/libraries/nest-translator/tsconfig.lib.json",
        "assets": ["components/libraries/nest-translator/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "components/libraries/nest-translator/jest.config.ts"
      }
    }
  }
}
