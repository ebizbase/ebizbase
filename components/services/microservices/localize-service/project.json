{
  "name": "localize-service",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "components/services/microservices/localize-service/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build-proto": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/src/protobuf"],
      "options": {
        "cwd": "components/libraries/protobuf",
        "command": "tsproto --path=./ --target=localize.proto --output=/workspaces/ebizbase/components/services/microservices/localize-service/src/protobuf"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": ["{options.outputPath}"],
      "dependsOn": ["build-proto"],
      "defaultConfiguration": "production",
      "options": {
        "target": "node",
        "compiler": "tsc",
        "sourceMap": true,
        "extractLicenses": false,
        "outputPath": "dist/components/services/microservices/localize-service",
        "main": "components/services/microservices/localize-service/src/main.ts",
        "tsConfig": "components/services/microservices/localize-service/tsconfig.app.json",
        "assets": [
          {
            "input": "components/libraries/protobuf",
            "glob": "*.proto",
            "output": "/protos"
          }
        ],
        "webpackConfig": "components/services/microservices/localize-service/webpack.config.js"
      },
      "configurations": {
        "development": {
          "optimization": false,
          "generatePackageJson": false
        },
        "production": {
          "optimization": true,
          "generatePackageJson": true
        }
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "localize-service:build",
        "runBuildTargetDependencies": false,
        "inspect": false,
        "runtimeArgs": ["--no-deprecation", "--max-old-space-size=32"]
      },
      "configurations": {
        "development": {
          "buildTarget": "localize-service:build:development"
        },
        "production": {
          "buildTarget": "localize-service:build:production"
        }
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "components/services/microservices/localize-service/jest.config.ts"
      }
    }
  }
}
