{
  "compileOnSave": false,
  "compilerOptions": {
    "allowJs": false,
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2020",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@ebizbase/common-translator-marker": ["libs/common-translator-marker/src/index.ts"],
      "@ebizbase/common-types": ["libs/common-types/src/index.ts"],
      "@ebizbase/nest-elite-logger": ["libs/nest-elite-logger/src/index.ts"],
      "@ebizbase/nest-grpc": ["libs/nest-grpc/src/index.ts"],
      "@ebizbase/nest-grpc-exceptions": ["libs/nest-grpc-exceptions/src/index.ts"],
      "@ebizbase/nest-grpc-logger": ["libs/nest-grpc-logger/src/index.ts"],
      "@ebizbase/nest-grpc-testing": ["libs/nest-grpc-testing/src/index.ts"],
      "@ebizbase/nest-http-logger": ["libs/nest-http-logger/src/index.ts"],
      "@ebizbase/nest-translator": ["libs/nest-translator/src/index.ts"],
      "@ebizbase/nx": ["tools/nx/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
